# Agent Usage — environment variables.
#
# Copy this file to `.env.local` and uncomment/edit the lines you need.
# Next.js loads `.env.local` automatically (see next.config.ts / Next docs).
# Every variable below is OPTIONAL — unset, the app reads live data from each
# tool's default data dir and every adapter is enabled.
#
# There is no `.env` checked in, no auth, no database, and no outbound network.
# These vars only (a) point an adapter at a non-default data dir, or
# (b) turn an adapter off.

# --- Data directory overrides ---------------------------------------------
# Point an adapter at an alternate config dir (e.g. for testing, a non-default
# install path, or the bundled demo data at ./demo-data). Each adapter reads its
# own var; it flows into every file lookup.
#
# Default paths:
#   CLAUDE_DIR        ~/.claude
#   CODEX_DIR         ~/.codex
#   OPENCODE_DIR      ~/.local/share/opencode
#   ANTIGRAVITY_DIR   ~/.gemini/antigravity-ide
#
# CLAUDE_DIR=/path/to/.claude
# CODEX_DIR=/path/to/.codex
# OPENCODE_DIR=/path/to/.local/share/opencode
# ANTIGRAVITY_DIR=/path/to/.gemini/antigravity-ide

# Demo data (ships in this repo):
# CLAUDE_DIR=./demo-data
# CODEX_DIR=./demo-data/codex
# OPENCODE_DIR=./demo-data/opencode
# ANTIGRAVITY_DIR=./demo-data/antigravity

# --- Enable / disable adapters --------------------------------------------
# Turn an adapter off with <SLUG>_ENABLED=0|false|no|off (case-insensitive).
# Unset (or any truthy value) = enabled. A disabled adapter drops out
# completely: no hub card, no nav pill, no per-agent route (its /<slug> 404s),
# and no contribution to the combined totals. Distinct from a missing data dir,
# which keeps the adapter listed with a muted "Not found" card.
#
# CLAUDE_ENABLED=1
# CODEX_ENABLED=1
# OPENCODE_ENABLED=1
# ANTIGRAVITY_ENABLED=1
#
# Examples:
#   OPENCODE_ENABLED=0 ANTIGRAVITY_ENABLED=false   # only Claude + Codex
#   CLAUDE_ENABLED=0                               # hide the Claude adapter